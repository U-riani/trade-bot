APP_ENV=local
LOG_LEVEL=INFO
TRADE_MODE=paper

EXCHANGE=binance
SYMBOL=BTCUSDT
BASE_ASSET=BTC
QUOTE_ASSET=USDT
TIMEFRAME=1m

BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

ENABLE_LIVE_TRADING=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_password
DATABASE_ENABLED=false
DATABASE_APPLY_MIGRATIONS_ON_START=false
DATABASE_USE_TIMESCALEDB=false

LOAD_RECENT_CANDLES_ON_START=true
STARTUP_CANDLE_LIMIT=100
STARTUP_CANDLE_MAX_AGE_SECONDS=180
STARTUP_CANDLE_GAP_TOLERANCE_SECONDS=2
STARTUP_REST_BACKFILL_ENABLED=true
STARTUP_REST_BACKFILL_LIMIT=100

INITIAL_QUOTE_BALANCE=1000
MAX_ORDER_USDT=10
MAX_POSITION_USDT=50
MAX_DAILY_LOSS_USDT=10
MAX_TRADES_PER_HOUR=5
STOP_LOSS_PCT=0.7
TAKE_PROFIT_PCT=1.2
COOLDOWN_SECONDS=60
ALLOW_ONLY_ONE_OPEN_POSITION=true
LOAD_PAPER_POSITION_ON_START=true

# Paper-only integration test helper. Keep disabled in normal usage.
PAPER_TEST_FORCE_BUY_ON_FIRST_CANDLE=false
PAPER_TEST_FORCE_BUY_QUOTE_AMOUNT=10

EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21
RSI_PERIOD=14
RSI_BUY_MIN=45
RSI_BUY_MAX=70
RSI_SELL_MIN=75

# V17 optional buy filters. 0 keeps the old EMA/RSI behavior.
TREND_EMA_PERIOD=0
MIN_EMA_GAP_PCT=0
ATR_PERIOD=0
MIN_ATR_PCT=0

# Historical/backtest candle source. Use production for realistic research;
# Binance testnet candles are synthetic and can contain unrealistic prices.
HISTORICAL_MARKET_DATA_SOURCE=production

BACKTEST_FEE_RATE_PCT=0.1
BACKTEST_SLIPPAGE_PCT=0.02

MARKET_EVENT_QUEUE_SIZE=2000
SIGNAL_QUEUE_SIZE=500
APPROVED_ORDER_QUEUE_SIZE=500
WEBSOCKET_RECONNECT_SECONDS=5
MARKET_DATA_STALE_SECONDS=120
